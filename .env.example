# AI Firewall Configuration
# Copy this file to .env and fill in values

# Similarity threshold for vector DB matches (0.0 - 1.0)
# Lower = more strict (blocks more), Higher = more lenient
SIMILARITY_THRESHOLD=0.50

# Firewall mode: "strict" | "moderate" | "permissive"
FIREWALL_MODE=strict

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# API settings
API_HOST=0.0.0.0
API_PORT=8000

# Optional: OpenAI API key for LLM pass-through (not required for firewall itself)
# OPENAI_API_KEY=sk-...
